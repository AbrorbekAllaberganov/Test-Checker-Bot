# ============================================================
# OMR Test Bot — Environment Variables
# Nusxa oling: cp .env.example .env
# Keyin BARCHA maydonlarni to'ldiring.
# ============================================================

# --- Telegram ---
BOT_TOKEN=8642853215:AAGsBfkRNFcgB0KW5Xzl3mwpuikfF7py_gQ
# Bot usernameni @ siz kiriting (base.html da ko'rsatiladi)
BOT_USERNAME=Test_Yordamchi_Robot

# Web Dashboard URL — bot ichidan menyuda "Dashboard" tugmasi paydo bo'ladi.
# HTTPS bo'lishi shart (Telegram Web App uchun). Bo'sh qoldirsa tugma ko'rinmaydi.
# Masalan: WEB_APP_URL=https://yourdomain.com/dashboard
WEB_APP_URL=

# --- PostgreSQL ---
# Docker compose ichida postgres container nomi
DATABASE_URL=postgresql+asyncpg://omruser:omrpass@postgres:5432/omrdb
SYNC_DATABASE_URL=postgresql+psycopg2://omruser:omrpass@postgres:5432/omrdb

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Admin ---
# Vergul bilan ajrating (bo'sh qoldirish mumkin)
ADMIN_TELEGRAM_IDS=

# --- FastAPI internal auth ---
INTERNAL_API_KEY=change-me-super-secret-internal-key

# --- Dashboard JWT autentifikatsiya ---
# Tasodifiy 32+ belgilik maxfiy kalit (python -c "import secrets; print(secrets.token_hex(32))" bilan yarating)
SECRET_KEY=change-me-use-a-random-32-char-secret
# JWT cookie muddati (kunlarda)
JWT_EXPIRE_DAYS=7

# --- Fayllar ---
# Docker volume paths (compose'da mount qilinadi)
PDF_OUTPUT_DIR=/data/pdfs
DEBUG_OUTPUT_DIR=/data/debug
TEMP_DIR=/tmp/omr_uploads

# --- Rasm chegarasi ---
MAX_IMAGE_MB=20

# --- OMR sozlamalari ---
# true/false: debug annotatsiya rasmi saqlash
OMR_DEBUG=false
# Doira "to'ldirilgan" deb hisoblanishi uchun minimal fill ratio
FILL_MIN=0.35
# Ikkita eng ko'p to'ldirilgan doira orasidagi minimal farq (ambiguous uchun)
FILL_MARGIN=0.15
# OMR rasterizatsiya DPI (PDF -> image)
OMR_DPI=200
# Warp natijasi o'lchami px (A4 @ ~200 DPI)
WARP_W=1654
WARP_H=2339

# --- Postgres container sozlamalari (docker-compose uchun) ---
POSTGRES_USER=omruser
POSTGRES_PASSWORD=omrpass
POSTGRES_DB=omrdb

# --- Loki Log Server ---
LOKI_URL=http://loki:3100/loki/api/v1/push
